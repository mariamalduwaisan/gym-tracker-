# ─── OpenRouter API Key ───────────────────────────────────────────────────────
# Get yours at https://openrouter.ai/keys
# If set here, users won't need to enter a key in the app UI.
# If left empty, users enter their own key — it's stored in their localStorage.
OPENROUTER_API_KEY=

# ─── App URL (used for OpenRouter HTTP-Referer header) ────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
